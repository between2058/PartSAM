# =============================================================================
# PartSAM FastAPI Microservice — Machine-specific configuration
#
# Usage:
#   cp .env.example .env
#   vim .env
#   docker compose up -d
#
# .env is gitignored — never commit it.
# =============================================================================

# -- CUDA arch list ------------------------------------------------------------
# "12.0" = RTX PRO 6000 (Blackwell) only, fastest build.
# Full list for multi-GPU compatibility:
# TORCH_CUDA_ARCH_LIST=8.0;8.6;8.9;9.0;10.0;12.0
TORCH_CUDA_ARCH_LIST=12.0

# -- Build parallelism ---------------------------------------------------------
MAX_JOBS=4

# -- Corporate proxy (leave empty if not needed) -------------------------------
HTTP_PROXY=
HTTPS_PROXY=

# -- GPU assignment ------------------------------------------------------------
# Run `nvidia-smi` on the host to see available devices.
GPU_ID=0

# -- Service config ------------------------------------------------------------
PARTSAM_PORT=8000
PARTSAM_DEVICE=cuda:0
PARTSAM_MAX_CONCURRENT=1
PARTSAM_SEMAPHORE_TIMEOUT=300
PARTSAM_MAX_FACES=200000
PARTSAM_BATCH_SIZE=32

# -- Output directory (persistent storage for segmented meshes) ----------------
PARTSAM_RESULTS_PATH=./results
